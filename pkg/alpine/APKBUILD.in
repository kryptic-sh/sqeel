# Maintainer: mxaddict <mxaddict@kryptic.sh>
#
# Auto-generated. Source: https://github.com/kryptic-sh/sqeel
# Edits made directly to a built .apk are not tracked. To change this
# APKBUILD, edit `pkg/alpine/APKBUILD.in` in the upstream repo and let
# `.github/workflows/release.yml` rebuild on the next tag.
pkgname=sqeel
pkgver={VERSION}
pkgrel=0
pkgdesc="Modal SQL workbench for the terminal"
url="https://sqeel.kryptic.sh/"
arch="x86_64"
license="MIT"
# !check  — no test suite shipped in the binary tarball.
# !strip  — binary is already stripped by the upstream release build,
#           and abuild's strip step rejects cross-built artifacts.
options="!check !strip"
source="sqeel-v$pkgver-x86_64-unknown-linux-musl.tar.gz::https://github.com/kryptic-sh/sqeel/releases/download/v$pkgver/sqeel-v$pkgver-x86_64-unknown-linux-musl.tar.gz"

package() {
    install -Dm755 "$srcdir/sqeel" "$pkgdir/usr/bin/sqeel"
    install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "$srcdir/README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"

    # Completions + man page, generated by the packaged binary itself
    # (musl build runs in the abuild container).
    "$srcdir/sqeel" --completions bash > sqeel.bash
    "$srcdir/sqeel" --completions zsh > _sqeel
    "$srcdir/sqeel" --completions fish > sqeel.fish
    "$srcdir/sqeel" --man > sqeel.1
    install -Dm644 sqeel.bash "$pkgdir/usr/share/bash-completion/completions/sqeel"
    install -Dm644 _sqeel "$pkgdir/usr/share/zsh/site-functions/_sqeel"
    install -Dm644 sqeel.fish "$pkgdir/usr/share/fish/vendor_completions.d/sqeel.fish"
    install -Dm644 sqeel.1 "$pkgdir/usr/share/man/man1/sqeel.1"
}

sha512sums="{SHA512_X86_64}  sqeel-v$pkgver-x86_64-unknown-linux-musl.tar.gz"
